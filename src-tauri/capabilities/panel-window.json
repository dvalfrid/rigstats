{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "panel-window",
  "description": "Capability for floating panel windows.",
  "windows": ["panel-*"],
  "permissions": [
    "core:event:default",
    "core:window:allow-start-dragging",
    "allow-get-settings",
    "allow-get-system-name",
    "allow-get-system-brand",
    "allow-get-cpu-info",
    "allow-get-gpu-info",
    "allow-broadcast-stats",
    "allow-save-panel-positions",
    "allow-toggle-floating-mode",
    "allow-close-window",
    "allow-start-window-drag",
    "allow-log-frontend-error",
    "allow-open-settings-window"
  ]
}
