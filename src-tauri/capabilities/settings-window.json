{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "settings-window",
  "description": "Capability for the settings popover window.",
  "windows": ["settings"],
  "permissions": [
    "allow-get-settings",
    "allow-preview-opacity",
    "allow-preview-profile",
    "allow-preview-visible-panels",
    "allow-preview-theme",
    "allow-save-settings",
    "allow-toggle-floating-mode",
    "allow-preview-floating-scale",
    "allow-hide-settings-window",
    "allow-show-settings-window",
    "allow-test-temp-alert",
    "allow-close-window"
  ]
}