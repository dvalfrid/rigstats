{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RigStats",
  "version": "1.0.0",
  "identifier": "se.codeby.rigstats",
  "mainBinaryName": "RigStats",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null,
      "capabilities": ["main-window", "settings-window"]
    },
    "windows": [
      {
        "label": "main",
        "title": "RigStats",
        "url": "index.html",
        "width": 450,
        "height": 1920,
        "resizable": false,
        "decorations": true,
        "transparent": true,
        "skipTaskbar": true,
        "visible": true,
        "focus": true,
        "useHttpsScheme": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "../assets/icon.ico",
      "../assets/tray.png"
    ]
  },
  "plugins": {}
}
