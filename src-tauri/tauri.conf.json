{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RigStats",
  "version": "1.0.1",
  "identifier": "se.codeby.rigstats",
  "mainBinaryName": "RigStats",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null,
      "capabilities": [
        "main-window",
        "settings-window",
        "about-window",
        "status-window"
      ]
    },
    "windows": [
      {
        "label": "main",
        "title": "RigStats",
        "url": "index.html",
        "width": 450,
        "height": 1920,
        "resizable": false,
        "decorations": true,
        "transparent": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": true,
        "useHttpsScheme": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerHooks": "../build/installer.nsh"
      }
    },
    "icon": [
      "../assets/icon.ico",
      "../assets/tray.png"
    ],
    "resources": {
      "../vendor/lhm/": "lhm/",
      "../build/lhm-default/": "lhm/defaults/"
    }
  },
  "plugins": {}
}
